#!/usr/bin/env bash
#
# wifi (wdutil, final)
#

set -euo pipefail

# Unicode signal blocks
signals=(▂ ▅ ▇)

# Get Wi-Fi info
raw="$(sudo wdutil info 2>/dev/null)"

if [[ -z "$raw" ]]; then
  echo "offline"
  exit 1
fi

# Parse fields (数値は必ず数値化する)
ssid=$(echo "$raw" | awk -F': ' '/^ *SSID/ {print $2}')
rssi=$(echo "$raw" | awk -F'[: ]+' '/^ *RSSI/ {print $3}')
rate_raw=$(echo "$raw" | awk -F'[: ]+' '/^ *Tx Rate/ {print $4}')

# Guard
if [[ -z "${rssi:-}" || -z "${rate_raw:-}" ]]; then
  echo "offline"
  exit 1
fi

# rate: 小数点以下を切り捨て（算術用）
rate_int=${rate_raw%.*}

# Build signal bar
signal=""
for ((i=0; i<${#signals[@]}; i++)); do
  if   (( i == 0 && rssi > -100 )) ||
       (( i == 1 && rssi > -80  )) ||
       (( i == 2 && rssi > -50  )); then
    signal+="${signals[i]} "
  else
    signal+="  "
  fi
done

# No Wi-Fi
if (( rate_int == 0 )); then
  echo "no_wifi"
  exit 1
fi

# Output
# example: MyWiFi 720Mbps ▂ ▅ ▇
echo "${ssid} ${rate_int}Mbps ${signal}"

