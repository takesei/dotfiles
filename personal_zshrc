export FPATH=$HOME/.zsh/completions:$FPATH
export DOCKER_DEFAULT_PLATFORM=linux/arm64

# Homebrew Activate
eval "$(/opt/homebrew/bin/brew shellenv)"

# Attach Session
if [[ $- == *i* ]] && command -v tmux >/dev/null 2>&1 && [ -z "$TMUX" ]; then
  if tmux has-session -t default 2>/dev/null; then
    exec tmux attach-session -t default
  else
    exec tmux new-session -s default -n main
  fi
fi


if type brew &>/dev/null; then
    export FPATH=$(brew --prefix)/share/zsh-completions:$FPATH
    zstyle ':completion:*:*:make:*' tag-order 'targets'
    autoload -Uz compinit
    compinit
fi

source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh

export OPENBLAS=$(brew --prefix openblas)
export CFLAGS="-falign-functions=8 ${CFLAGS}"
export LDFLAGS="-L/opt/homebrew/opt/openblas/lib"
export CPPFLAGS="-I/opt/homebrew/opt/openblas/include"
export PKG_CONFIG_PATH="/opt/homebrew/opt/openblas/lib/pkgconfig"

export NVM_DIR="$HOME/.nvm"
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && . "/opt/homebrew/opt/nvm/nvm.sh" # This loads nvm
[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && . "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" # This loads nvm bash_completion

export GOENV_ROOT=$HOME/.goenv
export PATH=$GOENV_ROOT/bin:$PATH
eval "$(goenv init -)"

export CARGO_HOME="$HOME/.cargo"
export PATH="$CARGO_HOME/bin:$PATH"

export MOCWORD_DATA="$HOME/.cache/mocword.sqlite"

source /Users/honyamorake/.config/op/plugins.sh

export RUST_BACKTRACE=1

eval "$(codex completion zsh)"

# Added by LM Studio CLI (lms)
export PATH="$PATH:/Users/honyamorake/.lmstudio/bin"
# End of LM Studio CLI section

# bun completions
[ -s "/Users/honyamorake/.bun/_bun" ] && source "/Users/honyamorake/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

