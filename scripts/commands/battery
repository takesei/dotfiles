#!/usr/bin/env bash

BATTERY_DANGER=20

has() {
    command -v "$1" >/dev/null 2>&1
}

get_battery_percentage() {
    has pmset || return 1
    pmset -g batt | awk -F';' 'NR==2 {print $1}' | awk '{print $NF}'
}

is_charging() {
    has pmset || return 1
    pmset -g batt | grep -q "AC Power"
}

get_remaining_time() {
    has pmset || return 1

    local t
    t="$(pmset -g batt | grep -oE '[0-9]+:[0-9]+')"

    [[ -z "$t" ]] && return 1
    printf '%s' "$t"
}

battery_icon() {
    local v="$1"
    if (( v >= 80 )); then printf '󰁹'
    elif (( v >= 60 )); then printf '󰁺'
    elif (( v >= 40 )); then printf '󰁻'
    elif (( v >= 20 )); then printf '󰁼'
    else printf '󰁽'
    fi
}

MODE="plain"
SHOW_REMAIN=0
SHOW_ICON=1

while [[ $# -gt 0 ]]; do
    case "$1" in
        --ansi) MODE="ansi" ;;
        --tmux) MODE="tmux" ;;
        --plain) MODE="plain" ;;
        -r|--remain) SHOW_REMAIN=1 ;;
        --icon) SHOW_ICON=1 ;;
        --no-icon) SHOW_ICON=0 ;;
        -h|--help)
            cat <<EOF 1>&2
usage: battery [options]

--ansi        ANSI color output (Nerd Font)
--tmux        tmux status output
--plain       plain text
-r, --remain  show remaining time
--icon        show icon (default)
--no-icon     disable icon
EOF
            exit 0
            ;;
        *)
            printf 'unknown option: %s\n' "$1" 1>&2
            exit 1
            ;;
    esac
    shift
done

pct="$(get_battery_percentage)" || exit 1
val="${pct%%%*}"
remain=""
icon=""
color=""

if (( SHOW_ICON )); then
    if is_charging; then
        icon="󰂄"
    else
        icon="$(battery_icon "$val")"
    fi
fi

if (( SHOW_REMAIN )); then
    remain="$(get_remaining_time 2>/dev/null)"
fi

case "$MODE" in
    tmux)
        if is_charging; then
            color="colour46"
        elif (( val < BATTERY_DANGER )); then
            color="red"
        else
            color="blue"
        fi
        printf '#[fg=%s]%s %s %s#[default]' \
            "$color" "$icon" "$pct" "$remain"
        ;;
    ansi)
        if is_charging; then
            color="32"
        elif (( val < BATTERY_DANGER )); then
            color="31"
        else
            color="34"
        fi
        printf '\033[%sm%s %s %s\033[0m\n' \
            "$color" "$icon" "$pct" "$remain"
        ;;
    plain)
        printf '%s %s %s\n' "$icon" "$pct" "$remain"
        ;;
esac
